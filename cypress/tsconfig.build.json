{
  "extends": "./tsconfig.json",
  "include": [
    "tmp/**/*",
    "../shell/types/shell/index.d.ts"
  ],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "tmp",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "emitDeclarationOnly": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "paths": {
      "~/*": ["*"],
      "@/*": ["*"],
      "@shell/*": ["shell/*"],
      "@pkg/*": ["shell/pkg/*"],
      "@components/*": ["pkg/rancher-components/src/components/*"]
    }
  }
}
