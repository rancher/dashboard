{
  "name": "@rancher/codemirror",
  "version": "0.3.3-alpha.3",
  "description": "Vue 3 CodeMirror 6 component library",
  "type": "module",
  "main": "./dist/rancher-codemirror.umd.cjs",
  "module": "./dist/rancher-codemirror.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rancher-codemirror.js",
      "require": "./dist/rancher-codemirror.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "yarn --cwd playground install --ignore-scripts",
    "playground": "yarn --cwd playground dev",
    "dev": "vite",
    "build": "run-p type-check build-decl build-only",
    "build-only": "vite build",
    "build-decl": "vue-tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist",
    "type-check": "vue-tsc --build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lang-yaml": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/search": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@replit/codemirror-vim": "^6.0.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.0.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/eslint-plugin": "^1.6.13",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.2",
    "vue": "^3.4.0",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
