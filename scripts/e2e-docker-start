#!/usr/bin/env bash
set -e

DIR=$(cd $(dirname $0)/..; pwd)

# See `script/build-e2e`
DASHBOARD_DIST=${DIR}/dist
EMBER_DIST=${DIR}/dist_ember

# Container Image Defaults
RANCHER_IMG_TAG=head
RANCHER_IMG_REGISTRY=
RANCHER_IMG_NAMESPACE=rancher
RANCHER_IMG_NAME=rancher

# Host port mapping (configurable to avoid conflicts, e.g. with MCP Gateway on port 80)
RANCHER_HOST_HTTP_PORT=${RANCHER_HOST_HTTP_PORT:-80}
RANCHER_HOST_HTTPS_PORT=${RANCHER_HOST_HTTPS_PORT:-443}
RANCHER_CONTAINER_NAME=${RANCHER_CONTAINER_NAME:-cypress}

# Docker volume args when mounting the locally-built UI into the container
VOLUME_ARGS="-v ${DASHBOARD_DIST}:/usr/share/rancher/ui-dashboard/dashboard -v ${EMBER_DIST}:/usr/share/rancher/ui"

# check if script invoke contains any argument. If so, adjust RANCHER_IMG_TAG
if [ $# -eq 1 ]; then
  RANCHER_IMG_TAG=$1
  # When an image is specified, we use that image, including its front-end, so we don't want the volume args to mount the locally-built UI
  VOLUME_ARGS=""
else
  # Get container image from branch-metadata
  BRANCH_DATA=$(./scripts/get-branch-metadata.sh ${GITHUB_BASE_REF:-${GITHUB_REF_NAME}})

  if [ -n "$BRANCH_DATA" ]; then
    REGISTRY=$(echo "$BRANCH_DATA" | jq -r '.e2e["rancher-image"].registry // ""')
    RANCHER_IMG_NAMESPACE=$(echo "$BRANCH_DATA" | jq -r '.e2e["rancher-image"].namespace')
    RANCHER_IMG_NAME=$(echo "$BRANCH_DATA" | jq -r '.e2e["rancher-image"].name')
    RANCHER_IMG_TAG=$(echo "$BRANCH_DATA" | jq -r '.e2e["rancher-image"].tag')

    if [ -n "$REGISTRY" ]; then
      RANCHER_IMG_REGISTRY="${REGISTRY}/"
    fi
  fi
fi

RANCHER_IMG=${RANCHER_IMG_REGISTRY}${RANCHER_IMG_NAMESPACE}/${RANCHER_IMG_NAME}:${RANCHER_IMG_TAG}

echo "Using Rancher Container Image: ${RANCHER_IMG}"

# Configure the Rancher server URL from start, similarly to how chart installations work
# The special host.docker.internal domain only works for Docker Desktop, not plain Docker Engine on linux, so using the special IP 172.17.0.1 to access the gateway of the default bridge network
if [ "$RANCHER_HOST_HTTPS_PORT" == "443" ]; then
  SERVER_URL="https://172.17.0.1"
else
  SERVER_URL="https://172.17.0.1:${RANCHER_HOST_HTTPS_PORT}"
fi

# we are now enabling the "oidc-provider" feature flag on install because we will need it for e2e testing (not enabled by default in non-prime versions)
# "oidc-provider" feature flag needs a system restart so it's not feasible to enable it as part of the test

docker run -d --restart=unless-stopped -p ${RANCHER_HOST_HTTP_PORT}:80 -p ${RANCHER_HOST_HTTPS_PORT}:443 ${VOLUME_ARGS} \
  -e CATTLE_UI_OFFLINE_PREFERRED=true \
  -e CATTLE_BOOTSTRAP_PASSWORD=password \
  -e CATTLE_PASSWORD_MIN_LENGTH=3 \
  -e CATTLE_SERVER_URL="${SERVER_URL}" \
  -e CATTLE_DEBUG=true \
  -e CATTLE_TRACE=true \
  --name ${RANCHER_CONTAINER_NAME} \
  --privileged \
  $RANCHER_IMG \
  --features=oidc-provider=true

docker ps

echo "Waiting for dashboard UI to be reachable (initial 20s wait) ..."

sleep 20

echo "Waiting for dashboard UI to be reachable ..."

okay=0

while [ $okay -lt 30 ]; do
  if [ "$RANCHER_HOST_HTTPS_PORT" == "443" ]; then
    HEALTH_URL="https://127.0.0.1/dashboard/"
  else
    HEALTH_URL="https://127.0.0.1:${RANCHER_HOST_HTTPS_PORT}/dashboard/"
  fi
  STATUS=$(curl --silent --head -k $HEALTH_URL | awk '/^HTTP/{print $2}')

  echo "Status: $STATUS (Try: $okay)"

  okay=$((okay+1))

  if [ "$STATUS" == "200" ]; then
    okay=100
  else
    sleep 5
  fi
done

if [ "$STATUS" != "200" ]; then
  echo "Dashboard did not become available in a reasonable time"
  exit 1
fi

echo "Dashboard UI is ready"

echo "Waiting for webhook to be running..."
okay=0
while [ $okay -lt 30 ] ; do
  if docker exec ${RANCHER_CONTAINER_NAME} kubectl -n cattle-system get po -l app=rancher-webhook | grep -q '1/1.*Running' ; then
    break
  else
    echo "Webhook not ready, checking again in 10s..."
    okay=$((okay+1))
    sleep 10
  fi
done
echo "Rancher is ready"
